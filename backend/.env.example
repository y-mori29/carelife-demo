# Carelife MVP — ローカル用ひな形（コピーして .env にリネームし、値を設定してください）

# GCP
PROJECT_ID=yorisoi-demo
GCS_BUCKET=yorisoi-demo-recordings

# ローカル開発時: サービスアカウントキー JSON のパス（backend 直下に sa-key.json を置く場合）
GOOGLE_APPLICATION_CREDENTIALS=./sa-key.json

# 通院報告生成用（Gemini）
GEMINI_API_KEY=

# モックモード（1 または true で GCS/STT/Gemini を使わずモック応答）
# MOCK_MODE=0

# サーバーポート（省略時 8081）
# PORT=8081

# LINE Bot（任意・後で使う場合）
# LINE_CHANNEL_ACCESS_TOKEN=
# LINE_CHANNEL_SECRET=
