# Carelife MVP — ローカル用ひな形（コピーして .env にリネームし、値を設定してください）

# GCP（実音声・文字起こし・要約を使う場合）
PROJECT_ID=yorisoi-demo
GCS_BUCKET=yorisoi-demo-recordings
GOOGLE_APPLICATION_CREDENTIALS=./sa-key.json

# 通院報告生成用（Gemini）。実機で必須。
GEMINI_API_KEY=

# モックモード（1 または true で GCS/STT/Gemini を使わずモック応答。ローカルで手軽に試すとき）
# MOCK_MODE=1

# サーバーポート（省略時 8081）
# PORT=8081

# LINE（「LINEに送信する」で報告を Push 送信する場合に backend でも必要。line-bot は別途 FRONTEND_URL 等を設定）
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
